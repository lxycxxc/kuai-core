<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.lxycx.kuaicore.mapper.MiddleCurdMapper">


    <select id="getPage" resultType="java.util.LinkedHashMap"  databaseId="mysql">
        <bind name="ppp" value="(page-1) * limit" />
        select d.* from(
        select ${field} from ${tablename} where 1=1
        <include refid="middle_wheres"/>
        <include refid="middle_order_by"/>
        ) d   limit #{ppp,jdbcType=DECIMAL},#{limit,jdbcType=DECIMAL}
    </select>

    <select id="getByOne" resultType="java.util.LinkedHashMap" databaseId="mysql">
        select ${field} from ${tablename} where 1=1
        <include refid="middle_wheres"/>
        <include refid="middle_order_by"/>
    </select>

    <delete id="deleteByOne" databaseId="mysql">
        delete from ${tablename} where 1=1
        <include refid="middle_wheres"/>
        limit 1
    </delete>
    <delete id="delete" databaseId="mysql">
        delete from ${tablename}
        <where>
            <include refid="middle_wheres"/>
        </where>
    </delete>
    <update id="update" databaseId="mysql">

        update ${tablename} set

        <foreach collection="set_data" index="k" item="v" separator=",">
            <choose>
                <when test="v!=null and v.toString().indexOf('(')==0">
                    `${k}`=${v}
                </when>
                <otherwise>
                    `${k}`=#{v,jdbcType=VARCHAR}
                </otherwise>
            </choose>
        </foreach>

        <where>
            <include refid="middle_wheres"/>
        </where>

    </update>
    <update id="updatePlus" databaseId="mysql" >

        update ${tablename} set

        <foreach collection="set_data.keys" item="k" separator=",">
            <bind  name="vvv"  value="set_data[k]" />
            `${k}`= ${vvv}
        </foreach>

        <where>
            <include refid="middle_wheres"/>
        </where>

    </update>
    <update id="insert" databaseId="mysql">

        insert into ${tablename}(
        <foreach collection="set_data.keys" item="k" open="" separator="," close=")" >
            `${k}`
        </foreach>

        values(
        <foreach collection="set_data.values" item="v" open="" separator="," close=")" >
            <choose>
                <when test="v!=null and v.toString().indexOf('MAX(')>=0">
                    (select ${v} from ${tablename} as a)
                </when>
                <when test="v!=null and v.toString().indexOf('(')==0">
                    ${v}
                </when>
                <otherwise>
                    #{v,jdbcType=VARCHAR}
                </otherwise>
            </choose>
        </foreach>

    </update>



</mapper>
